#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
graalvm_home="/Library/Java/JavaVirtualMachines/graalvm-25.jdk/Contents/Home"

cd "$script_dir"
export GRAALVM_HOME="$graalvm_home"
export PATH="$GRAALVM_HOME/bin:$PATH"

printf '==> Building NestQL executable with %s\n' "$GRAALVM_HOME"
mvn -Pnative,jdbc-common -DskipTests clean package

[[ -x target/nestql ]] || {
  printf 'Error: Expected executable was not produced at %s/target/nestql.\n' "$script_dir" >&2
  exit 1
}
