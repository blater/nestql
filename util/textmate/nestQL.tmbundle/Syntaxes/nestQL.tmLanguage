<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>name</key>
  <string>nestQL</string>
  <key>scopeName</key>
  <string>source.nestql</string>
  <key>fileTypes</key>
  <array>
    <string>nql</string>
  </array>
  <key>uuid</key>
  <string>03A43DF4-410D-4C59-8D5E-DF41AB1F10DF</string>
  <key>foldingStartMarker</key>
  <string>(?ix)^\s*(?:select|insert\b.*\bselect|capture\b.*$|/\*)</string>
  <key>foldingStopMarker</key>
  <string>(?ix)(?:;|\\g)\s*$|\*/</string>
  <key>patterns</key>
  <array>
    <dict><key>include</key><string>#comments</string></dict>
    <dict><key>include</key><string>#include-directives</string></dict>
    <dict><key>include</key><string>#templates</string></dict>
    <dict><key>include</key><string>#output-directive</string></dict>
    <dict><key>include</key><string>#hierarchy-union</string></dict>
    <dict><key>include</key><string>#handlers</string></dict>
    <dict><key>include</key><string>#mapping-path</string></dict>
    <dict><key>include</key><string>#nestql-keywords</string></dict>
    <dict><key>include</key><string>#sql</string></dict>
    <dict><key>include</key><string>#terminators</string></dict>
  </array>
  <key>repository</key>
  <dict>
    <key>comments</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key><string>comment.line.double-dash.nestql</string>
          <key>begin</key><string>--</string>
          <key>beginCaptures</key><dict><key>0</key><dict><key>name</key><string>punctuation.definition.comment.nestql</string></dict></dict>
          <key>end</key><string>$</string>
        </dict>
        <dict>
          <key>name</key><string>comment.block.nestql</string>
          <key>begin</key><string>/\*</string>
          <key>beginCaptures</key><dict><key>0</key><dict><key>name</key><string>punctuation.definition.comment.begin.nestql</string></dict></dict>
          <key>end</key><string>\*/</string>
          <key>endCaptures</key><dict><key>0</key><dict><key>name</key><string>punctuation.definition.comment.end.nestql</string></dict></dict>
        </dict>
      </array>
    </dict>
    <key>include-directives</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key><string>meta.preprocessor.include.nestql</string>
          <key>match</key><string>(?ix)^\s*(include|submapping)\s+('(?:[^']|'')*')</string>
          <key>captures</key>
          <dict>
            <key>1</key><dict><key>name</key><string>keyword.control.import.nestql</string></dict>
            <key>2</key><dict><key>name</key><string>string.quoted.single.filename.nestql</string></dict>
          </dict>
        </dict>
      </array>
    </dict>
    <key>templates</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key><string>constant.character.escape.template.nestql</string>
          <key>match</key><string>\\\$\{[^}\r\n]*\}</string>
        </dict>
        <dict>
          <key>name</key><string>meta.interpolation.parameter.nestql</string>
          <key>match</key><string>(?&lt;!\\)(\$\{)([^}:\r\n]+)(?:(:)([^}\r\n]*))?(\})</string>
          <key>captures</key>
          <dict>
            <key>1</key><dict><key>name</key><string>punctuation.definition.template.begin.nestql</string></dict>
            <key>2</key><dict><key>name</key><string>variable.other.parameter.nestql</string></dict>
            <key>3</key><dict><key>name</key><string>punctuation.separator.default.nestql</string></dict>
            <key>4</key><dict><key>name</key><string>string.unquoted.default.nestql</string></dict>
            <key>5</key><dict><key>name</key><string>punctuation.definition.template.end.nestql</string></dict>
          </dict>
        </dict>
      </array>
    </dict>
    <key>output-directive</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key><string>meta.output.directive.nestql</string>
          <key>match</key><string>(?i)\b(output)\s+(xml|json|csv|yaml)\b</string>
          <key>captures</key>
          <dict>
            <key>1</key><dict><key>name</key><string>keyword.control.output.nestql</string></dict>
            <key>2</key><dict><key>name</key><string>constant.language.output-format.nestql</string></dict>
          </dict>
        </dict>
      </array>
    </dict>
    <key>hierarchy-union</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key><string>keyword.control.hierarchy-union.nestql</string>
          <key>match</key><string>(?i)\b(?:hierarchy\s+union|xmlunion)\b</string>
        </dict>
      </array>
    </dict>
    <key>handlers</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key><string>support.function.handler.nestql</string>
          <key>match</key><string>(?i)\b(?:onerror|onwarning)(?=\s*\()</string>
        </dict>
        <dict>
          <key>name</key><string>constant.language.handler-flag.nestql</string>
          <key>match</key><string>(?i)\b(?:abort|rollback)\b</string>
        </dict>
      </array>
    </dict>
    <key>mapping-path</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key><string>meta.mapping.path.nestql</string>
          <key>begin</key><string>\{</string>
          <key>beginCaptures</key><dict><key>0</key><dict><key>name</key><string>punctuation.section.mapping.begin.nestql</string></dict></dict>
          <key>end</key><string>\}</string>
          <key>endCaptures</key><dict><key>0</key><dict><key>name</key><string>punctuation.section.mapping.end.nestql</string></dict></dict>
          <key>patterns</key>
          <array>
            <dict><key>include</key><string>#comments</string></dict>
            <dict><key>include</key><string>#templates</string></dict>
            <dict><key>include</key><string>#strings</string></dict>
            <dict>
              <key>name</key><string>variable.other.attribute.nestql</string>
              <key>match</key><string>@(?:[A-Za-z_$][A-Za-z_$0-9]*|"[^"]*"|\[[^\]]*\]|`[^`]*`)</string>
            </dict>
            <dict>
              <key>name</key><string>support.function.mapping.nestql</string>
              <key>match</key><string>(?i)\bappend(?=\s*\()</string>
            </dict>
            <dict>
              <key>name</key><string>variable.parameter.mapping-option.nestql</string>
              <key>match</key><string>(?i)\b(?:key|uid|volatile|literal|xpath|autoincrement)(?=\s*:)</string>
            </dict>
            <dict>
              <key>name</key><string>constant.language.boolean.nestql</string>
              <key>match</key><string>(?i)\b(?:true|false)\b</string>
            </dict>
            <dict>
              <key>name</key><string>constant.language.separator.nestql</string>
              <key>match</key><string>(?i)\bspace\b</string>
            </dict>
            <dict><key>include</key><string>#numbers</string></dict>
            <dict><key>include</key><string>#quoted-identifiers</string></dict>
            <dict>
              <key>name</key><string>variable.other.property.nestql</string>
              <key>match</key><string>\b[A-Za-z_$][A-Za-z_$0-9]*\b</string>
            </dict>
            <dict>
              <key>name</key><string>punctuation.accessor.path.nestql</string>
              <key>match</key><string>\.</string>
            </dict>
            <dict>
              <key>name</key><string>punctuation.separator.mapping.nestql</string>
              <key>match</key><string>[:,()]</string>
            </dict>
          </array>
        </dict>
      </array>
    </dict>
    <key>nestql-keywords</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key><string>keyword.control.mapping.nestql</string>
          <key>match</key><string>(?i)\b(?:into|structure|key|createsnew|returns)\b</string>
        </dict>
        <dict>
          <key>name</key><string>keyword.control.null-policy.nestql</string>
          <key>match</key><string>(?i)\babsent\s+on\s+null\b</string>
        </dict>
        <dict>
          <key>name</key><string>keyword.control.metadata.nestql</string>
          <key>match</key><string>(?i)\b(?:using|schema|xmlroot|namespace)\b</string>
        </dict>
        <dict>
          <key>name</key><string>keyword.control.statement.nestql</string>
          <key>match</key><string>(?i)\b(?:autocommit|catalog|capture|literal|xmlselect|execute\s+procedure|from\s+temp)\b</string>
        </dict>
        <dict>
          <key>name</key><string>constant.language.toggle.nestql</string>
          <key>match</key><string>(?i)(?&lt;=\bautocommit\s)(?:on|off)\b</string>
        </dict>
      </array>
    </dict>
    <key>sql</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict><key>include</key><string>#strings</string></dict>
        <dict><key>include</key><string>#quoted-identifiers</string></dict>
        <dict><key>include</key><string>#numbers</string></dict>
        <dict>
          <key>name</key><string>keyword.control.sql.nestql</string>
          <key>match</key><string>(?i)\b(?:select|insert|update|delete|merge|from|where|set|values|returning|with|recursive|as|distinct|all|into|case|when|then|else|end|begin|if|loop|while|do|declare)\b</string>
        </dict>
        <dict>
          <key>name</key><string>keyword.control.clause.sql.nestql</string>
          <key>match</key><string>(?i)\b(?:join|inner|left|right|full|outer|cross|natural|lateral|on|using|group\s+by|having|order\s+by|partition\s+by|window|over|rows|range|groups|between|unbounded|preceding|following|current\s+row|asc|desc|nulls\s+(?:first|last)|limit|offset|fetch|first|next|only|for\s+update|union|intersect|except)\b</string>
        </dict>
        <dict>
          <key>name</key><string>keyword.operator.logical.sql.nestql</string>
          <key>match</key><string>(?i)\b(?:and|or|not|is|in|like|ilike|similar\s+to|escape|exists|any|some|between)\b</string>
        </dict>
        <dict>
          <key>name</key><string>keyword.other.ddl.sql.nestql</string>
          <key>match</key><string>(?i)\b(?:create|alter|drop|truncate|rename|table|view|index|sequence|schema|database|temporary|temp|primary\s+key|foreign\s+key|references|unique|check|constraint|default|generated|identity|cascade|restrict|add|column)\b</string>
        </dict>
        <dict>
          <key>name</key><string>storage.type.sql.nestql</string>
          <key>match</key><string>(?i)\b(?:bigint|bigserial|binary|bit|blob|boolean|char|character|clob|date|datetime|decimal|double|float|int|integer|interval|json|jsonb|numeric|real|serial|smallint|smallserial|text|time|timestamp|tinyint|uuid|varbinary|varchar|xml)(?:\s+(?:with|without)\s+time\s+zone)?\b</string>
        </dict>
        <dict>
          <key>name</key><string>constant.language.sql.nestql</string>
          <key>match</key><string>(?i)\b(?:null|true|false|unknown|current_date|current_time|current_timestamp|localtime|localtimestamp)\b</string>
        </dict>
        <dict>
          <key>name</key><string>support.function.aggregate.sql.nestql</string>
          <key>match</key><string>(?i)\b(?:avg|count|max|min|string_agg|sum|array_agg|json_agg|json_object_agg)(?=\s*\()</string>
        </dict>
        <dict>
          <key>name</key><string>support.function.builtin.sql.nestql</string>
          <key>match</key><string>(?i)\b(?:cast|coalesce|convert|extract|nullif|upper|lower|trim|substring|replace|concat|length|round|floor|ceil|abs|dateadd|datediff|row_number|rank|dense_rank|lead|lag|first_value|last_value)(?=\s*\()</string>
        </dict>
        <dict>
          <key>name</key><string>keyword.operator.sql.nestql</string>
          <key>match</key><string>&lt;=|&gt;=|&lt;&gt;|!=|:=|\|\||[-+*/%=&lt;&gt;|^~]</string>
        </dict>
        <dict>
          <key>name</key><string>punctuation.separator.sql.nestql</string>
          <key>match</key><string>[(),.]</string>
        </dict>
      </array>
    </dict>
    <key>strings</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict>
          <key>name</key><string>string.quoted.single.sql.nestql</string>
          <key>begin</key><string>'</string>
          <key>beginCaptures</key><dict><key>0</key><dict><key>name</key><string>punctuation.definition.string.begin.nestql</string></dict></dict>
          <key>end</key><string>'(?!')</string>
          <key>endCaptures</key><dict><key>0</key><dict><key>name</key><string>punctuation.definition.string.end.nestql</string></dict></dict>
          <key>patterns</key>
          <array>
            <dict><key>include</key><string>#templates</string></dict>
            <dict><key>name</key><string>constant.character.escape.sql.nestql</string><key>match</key><string>''</string></dict>
          </array>
        </dict>
      </array>
    </dict>
    <key>quoted-identifiers</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict><key>name</key><string>variable.other.quoted.double.sql.nestql</string><key>match</key><string>"[^"\r\n]*"</string></dict>
        <dict><key>name</key><string>variable.other.quoted.bracket.sql.nestql</string><key>match</key><string>\[[^\]\r\n]*\]</string></dict>
        <dict><key>name</key><string>variable.other.quoted.backtick.sql.nestql</string><key>match</key><string>`[^`\r\n]*`</string></dict>
      </array>
    </dict>
    <key>numbers</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict><key>name</key><string>constant.numeric.sql.nestql</string><key>match</key><string>(?&lt;![$\w])(?:\d+(?:\.\d*)?|\.\d+)(?:[eE][+-]?\d+)?\b</string></dict>
      </array>
    </dict>
    <key>terminators</key>
    <dict>
      <key>patterns</key>
      <array>
        <dict><key>name</key><string>punctuation.terminator.statement.nestql</string><key>match</key><string>;|\\[gG]\b</string></dict>
      </array>
    </dict>
  </dict>
</dict>
</plist>
