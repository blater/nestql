/*
 * Highlighting fixture for the nestQL language surface.
 * The statements use illustrative tables and are not intended to run together.
 */

include 'setup.sql'
submapping 'shared/person-summary.nql'

output json;
autocommit off;
catalog;

select using schema 'people.xsd' xmlroot = people namespace = 'urn:people'
  p.id as person_id into {people.person.@id},
  p.first_name into {people.person.name:append(space)},
  p.last_name into {people.person.name:append(space)},
  p.nickname into {people.person.nickname} absent on null
from person p
where p.region = '${region:EMEA}'
order by p.last_name asc, p.id desc
structure {people.person} key (p.tenant_id, p.id);

select
  c.id into {customers.customer.id},
  ph.id into {customers.customer.phones.phone.id}
from customer c
join phone ph on ph.customer_id = c.id

hierarchy union

select
  c.id into {customers.customer.id},
  e.id into {customers.customer.emails.email.id}
from customer c
join email e on e.customer_id = c.id
structure
  {customers.customer} key (c.id),
  {customers.customer.phones.phone} key (ph.id),
  {customers.customer.emails.email} key (e.id);

-- Legacy aliases remain highlighted for scripts that still contain them.
select id into {items.item.id}
from item
xmlunion
select id into {items.item.id} from archived_item
order by id createsnew {items.item};

capture 'people_snapshot'
select id, first_name from person order by id;

insert into person (first_name, status)
values ({message.person.firstname}, 'NEW')
returns person_id into {message.person.id};
onError('insert failed', abort, rollback);

insert into audit_log from temp 'people_snapshot' (person_id, first_name)
values ({id}, {first_name});

update person
set first_name = upper({message.person.firstname}),
    updated_at = current_timestamp
where person_id = {message.person.@id}
returns updated_at into {message.person.updatedAt};
onWarning('ambiguous input', rollback);

delete from person
where person_id = {message.person.id};

execute procedure update_person(
  person_id = {message.person.id, key:1},
  request_id = {message.request.id, uid:true},
  updated_at = {message.person.updatedAt, volatile:true}
);

literal create table audit_log (
  id bigint generated by default as identity primary key,
  message varchar(200) not null
)\G

-- Escaped templates are literal: \${not_expanded}
autocommit on;
